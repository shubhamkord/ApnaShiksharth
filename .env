# ============================================================
#  APNA SHIKSHARTH — Environment Variables
#  Copy this file to .env and fill in real values before deploy
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# JWT Secret  (change this to a long random string in production)
JWT_SECRET=apnashiksharth_super_secret_jwt_key_2025_change_in_prod

# Cookie settings
COOKIE_SECURE=false

# ---- SMTP (Hostinger) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@apnashiksharth.com
SMTP_PASS=YOUR_EMAIL_PASSWORD_HERE

# Recipient emails
CONTACT_EMAIL_TO=support@apnashiksharth.com
CONTACT_EMAIL_CC=info@apnashiksharth.com
